# PostgreSQL (Railway, local, etc). Добавь ?connection_limit=10 чтобы избежать pool timeout.
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public&connection_limit=10"
PORT=3000
# Telegram bot (optional; bot won't start if unset)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# URL of the frontend Mini App for "Open" button (HTTPS in production)
# WEB_APP_URL=https://your-app.vercel.app
# Public URL of this backend (e.g. https://xxx.up.railway.app). If set, bot uses webhook:
# Telegram sends updates here when user opens bot / sends /start → server wakes before user taps "Open".
# PUBLIC_URL=https://your-backend.up.railway.app

