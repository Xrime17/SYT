generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanType {
  FREE
  PRO
}

enum TaskType {
  TASK
  GOAL
  NOTE
}

enum TaskStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

model User {
  id           String   @id @default(uuid())
  telegramId   BigInt   @unique
  username     String?
  firstName    String
  lastName     String?
  timezone     String   @default("UTC")
  planType     PlanType @default(FREE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks          Task[]
  completions    TaskCompletion[]
  homeCategories HomeCategory[]
  habits         Habit[]
  habitDayLogs   HabitDayLog[]
}

/// Привычка: полоса кружков на Home; дневной прогресс в `HabitDayLog` (локальная дата в TZ пользователя).
model Habit {
  id           String    @id @default(uuid())
  userId       String
  title        String
  /// Пресет иконки на клиенте (water, reading, book, clock, list, flame).
  iconKey      String
  targetPerDay Int       @default(1)
  sortOrder    Int       @default(0)
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitDayLog[]

  @@index([userId])
  @@index([userId, sortOrder])
}

/// Счётчик за календарный день в таймзоне пользователя (`localDate` = YYYY-MM-DD).
model HabitDayLog {
  id        String @id @default(uuid())
  habitId   String
  userId    String
  localDate String
  count     Int    @default(0)

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, localDate])
  @@index([userId, localDate])
}

/// Категория для задач (чипы / фильтр). Подзаголовок «habits» на Home считает модель `Habit`, не `HomeCategory`.
model HomeCategory {
  /// Первичный ключ записи.
  id          String   @id @default(uuid())
  /// Владелец; у одного пользователя много категорий.
  userId      String
  /// Полная подпись (a11y, будущие подсказки, списки).
  label       String
  /// Короткий текст на круглом чипе (как Wa / Re на текущем frontend).
  shortLabel  String
  /// Стабильный ключ для маппинга иконки на клиенте (water, reading, …; для кастомных — свой slug).
  iconKey     String
  /// Опциональный emoji; если задан, клиент может показать его вместо/вместе с иконкой.
  emoji       String?
  /// Порядок слева направо в полосе (меньше — раньше).
  sortOrder   Int      @default(0)
  /// Время создания строки (аудит, сортировка «как добавляли»).
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, iconKey])
  @@index([userId])
  @@index([userId, sortOrder])

  tasks Task[]
}

model Task {
  id                String          @id @default(uuid())
  userId            String
  title             String
  description       String?
  type              TaskType        @default(TASK)
  status            TaskStatus      @default(ACTIVE)
  priority          Priority        @default(MEDIUM)
  dueDate           DateTime?
  /// Опциональная категория Home; null — без категории (старые задачи и сброс).
  categoryId        String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  recurringRuleId   String?
  generatedDate     DateTime?

  user              User            @relation(fields: [userId], references: [id])
  homeCategory      HomeCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  completions       TaskCompletion[]
  generatedByRule   RecurringRule?   @relation("GeneratedByRule", fields: [recurringRuleId], references: [id])
  recurring         RecurringRule?   @relation("TemplateTask")
  /// Не более одной строки `Reminder` на задачу (см. комментарий у модели Reminder).
  reminder          Reminder?

  @@unique([recurringRuleId, generatedDate])
  @@index([userId])
  @@index([recurringRuleId])
  @@index([categoryId])
}

model TaskCompletion {
  id          String   @id @default(uuid())
  taskId      String
  userId      String
  completedAt DateTime @default(now())

  task        Task     @relation(fields: [taskId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
}

model RecurringRule {
  id             String     @id @default(uuid())
  taskId         String     @unique
  frequency      Frequency
  interval       Int        @default(1)
  daysOfWeek     Int[]      // 1-7 (ISO weekday: Mon=1, Sun=7)
  endDate        DateTime?

  task           Task       @relation("TemplateTask", fields: [taskId], references: [id])
  generatedTasks Task[]     @relation("GeneratedByRule")
}

/// Ровно одно напоминание на задачу: колокольчик Home, /reminders и /remind в Telegram
/// делят одну строку (upsert по taskId). Конфликт: при нескольких старых строках миграция
/// оставляет одну (приоритет unsent, затем меньший id). После отправки sent=true — колокольчик
/// «выкл» до следующего включения (новый remindAt + sent=false через upsert).
model Reminder {
  id        String   @id @default(uuid())
  taskId    String   @unique
  remindAt  DateTime
  sent      Boolean  @default(false)

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([remindAt])
  @@index([sent])
}

